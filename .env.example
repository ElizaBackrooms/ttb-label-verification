# Copy this file to `.env` and fill in values if you extend the app with cloud OCR/vision.
# The included prototype runs locally with Tesseract and does NOT require these keys.

# Optional: custom Tesseract binary path (if not on PATH)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Optional: Azure AI Document Intelligence (not wired in this prototype)
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_DOCUMENT_INTELLIGENCE_KEY=your-key-here

# Optional: OpenAI / Azure OpenAI vision (not wired in this prototype)
# OPENAI_API_KEY=your-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-key-here
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
